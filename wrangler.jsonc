{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "matty-dashboard",
  "main": "src/index.js",
  "compatibility_date": "2026-07-08",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "GARMIN_KV",
      "id": "e1c7b9f212c44b2d95accc79df8f397c"
    }
  ],
  "vars": {
    "GARMIN_EMAIL": "matty.milias@icloud.com",
  }
}